# Dashboard backend reads these from the process environment.
# It does not auto-load this file.

CYBERBOSS_STATE_DIR=/home/your-user/.cyberboss
CYBERBOSS_LOG_DIR=/home/your-user/logs/cyberboss

CYBERBOSS_DASHBOARD_HOST=0.0.0.0
CYBERBOSS_DASHBOARD_PORT=3011
CYBERBOSS_DASHBOARD_AUTH_PASSWORD=change-this-password
CYBERBOSS_DASHBOARD_AUTH_SESSION_DAYS=30

# Optional overrides
CYBERBOSS_DASHBOARD_DIST_DIR=/path/to/dashboard/frontend/dist
CYBERBOSS_PROJECT_ROOT=/path/to/cyberboss
CYBERBOSS_WEIXIN_INSTRUCTIONS_FILE=/path/to/weixin-instructions.md
